generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PasswordReset {
  id        String   @id @db.Uuid
  userId    String   @db.Uuid
  token     String
  expiresAt DateTime @db.Timestamptz(3)
  usedAt    DateTime @db.Timestamptz(3)
  users     User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model RefreshToken {
  id        String   @id @db.Uuid
  token     String
  userId    String   @db.Uuid
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  users     User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Review {
  id        String     @id @db.Uuid
  produkId  String     @db.Uuid
  userId    String     @db.Uuid
  rating    rating_int
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  produk    Produk     @relation(fields: [produkId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users     User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Kategori {
  id        String   @id @db.Uuid
  nama      String   @db.VarChar
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  Produk    Produk[]
}

model Produk {
  id         String         @id @db.Uuid
  tokoId     String         @db.Uuid
  nama       String         @db.VarChar
  deskripsi  String
  harga      Decimal        @db.Decimal
  material   String         @db.VarChar
  warna      String         @db.VarChar
  berat      Int
  dimensi    Int
  status     status_product
  viewCount  Int
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  kategoriId String         @db.Uuid
  garansi    String         @db.VarChar
  sku        String         @db.VarChar(15)
  kategori   Kategori       @relation(fields: [kategoriId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toko       Toko           @relation(fields: [tokoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Review     Review[]
}

model Toko {
  id            String    @id @db.Uuid
  userId        String    @db.Uuid
  namaToko      String    @db.VarChar
  alamatToko    String
  isVerified    Boolean
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  deskripsiToko String?   @db.VarChar
  instagramToko String?   @db.VarChar
  nomorToko     String    @db.VarChar(15)
  jamBuka       DateTime? @db.Time(6)
  jamTutup      DateTime? @db.Time(6)
  Produk        Produk[]
  user          User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model User {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String          @db.VarChar(50)
  password      String          @db.VarChar(50)
  passwordHash  String
  role          user_role       @default(user)
  createdAt     DateTime        @db.Timestamptz(6)
  updatedAt     DateTime        @db.Timetz(6)
  isActive      Boolean         @default(true)
  nomorTelepon  String          @db.VarChar(15)
  PasswordReset PasswordReset[]
  RefreshToken  RefreshToken[]
  Review        Review[]
  Toko          Toko[]
}

enum rating_int {
  STAR_1 @map("1")
  STAR_2 @map("2")
  STAR_3 @map("3")
  STAR_4 @map("4")
  STAR_5 @map("5")
}

enum status_product {
  Active
  Draft
  Inactive
}

/// This enum is commented in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
enum user_role {
  admin
  seller
  user
}
