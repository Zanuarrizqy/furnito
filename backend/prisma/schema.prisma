generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String    @id @db.Uuid
  name      String    @db.VarChar
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  Product   Product[]
}

model PasswordReset {
  id        String   @id @db.Uuid
  userId    String   @db.Uuid
  token     String
  expiresAt DateTime @db.Timestamptz(3)
  usedAt    DateTime @db.Timestamptz(3)
  Users     Users    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Product {
  id          String         @id @db.Uuid
  storeId     String         @db.Uuid
  name        String         @db.VarChar
  description String
  price       Decimal        @db.Decimal
  material    String         @db.VarChar
  color       String         @db.VarChar
  weight      Int
  dimension   Int
  status      status_product
  viewCount   Int
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  categoryId  String         @db.Uuid
  Category    Category       @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Store       Store          @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Review      Review[]
}

model RefreshToken {
  id        String   @id @db.Uuid
  token     String
  userId    String   @db.Uuid
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  Users     Users    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Review {
  id        String      @id @db.Uuid
  productId String      @db.Uuid
  userId    String      @db.Uuid
  rating    rating_int?
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  Product   Product     @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Users     Users       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Store {
  id         String    @id @db.Uuid
  userId     String    @db.Uuid
  name       String    @db.VarChar
  address    String
  isVerified Boolean
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  Product    Product[]
  Users      Users     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Store_userId_user_fkey")
}

model Users {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String          @db.VarChar(50)
  password      String          @db.VarChar(50)
  passwordHash  String
  role          user_role       @default(user)
  createdAt     DateTime        @db.Timestamptz(6)
  updatedAt     DateTime        @db.Timetz(6)
  isActive      Boolean         @default(true)
  PasswordReset PasswordReset[]
  RefreshToken  RefreshToken[]
  Review        Review[]
  Store         Store[]
}

enum rating_int {
  STAR_1 @map("1")
  STAR_2 @map("2")
  STAR_3 @map("3")
  STAR_4 @map("4")
  STAR_5 @map("5")
}

enum status_product {
  Active
  Draft
  Inactive
}

/// This enum is commented in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
enum user_role {
  admin
  seller
  user
}
